{
  "name": "@tipt/sdk",
  "version": "0.1.2",
  "description": "Unified TIPT SDK for Spark-aware MPP charge/session flows on client, server, and extension wallet bridges.",
  "license": "MIT",
  "author": "austinvach",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.cjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    },
    "./extension": {
      "types": "./dist/extension.d.ts",
      "import": "./dist/extension.js",
      "require": "./dist/extension.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "prepare": "pnpm run build",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "lightning",
    "mpp",
    "bitcoin",
    "402",
    "payment-required",
    "browser-extension",
    "spark"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/austinvach/tipt.git"
  },
  "bugs": {
    "url": "https://github.com/austinvach/tipt/issues"
  },
  "homepage": "https://github.com/austinvach/tipt/tree/main/sdk#readme",
  "dependencies": {
    "@buildonspark/spark-sdk": "^0.8.6",
    "@noble/hashes": "^2.0.1",
    "light-bolt11-decoder": "^3.2.0",
    "mppx": "^0.8.4",
    "viem": "^2.52.2"
  },
  "devDependencies": {
    "happy-dom": "^12.10.3",
    "tsup": "^8.3.5",
    "typescript": "~5.9.3",
    "vitest": "^1.0.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
