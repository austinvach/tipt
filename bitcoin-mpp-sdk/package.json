{
  "name": "bitcoin-mpp-sdk",
  "version": "0.1.0",
  "type": "module",
  "description": "Thin Spark-powered bitcoin payment method SDK for mppx.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mpp",
    "mppx",
    "bitcoin",
    "lightning",
    "spark",
    "sdk"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    }
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build",
    "typecheck": "tsc --noEmit",
    "typecheck:examples": "tsc -p tsconfig.examples.json",
    "test": "node --import tsx/esm --test src/__tests__/*.test.ts",
    "example:server": "tsx examples/server.ts",
    "example:client": "tsx examples/client.ts",
    "example:server-session": "tsx examples/server-session.ts",
    "example:client-session": "tsx examples/client-session.ts"
  },
  "peerDependencies": {
    "@buildonspark/spark-sdk": "^0.7.1",
    "mppx": "^0.8.1"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "light-bolt11-decoder": "^3.2.0"
  },
  "devDependencies": {
    "@buildonspark/spark-sdk": "^0.7.1",
    "@types/node": "^24.3.0",
    "mppx": "^0.8.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  }
}
