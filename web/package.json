{
  "name": "@tipt/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"const ua = process.env.npm_config_user_agent; if (!ua || ua.startsWith('pnpm/')) process.exit(0); console.error('Use pnpm instead'); process.exit(1)\" && rm -f package-lock.json yarn.lock",
    "dev": "next dev --hostname 0.0.0.0",
    "prebuild": "pnpm --filter @tipt/sdk run build",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@buildonspark/spark-sdk": "^0.8.6",
    "@google/genai": "^1.44.0",
    "@tipt/sdk": "workspace:*",
    "lucide-react": "^0.545.0",
    "mppx": "^0.8.4",
    "next": "^15.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "viem": "^2.52.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.14",
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.1.14",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3"
  },
  "packageManager": "pnpm@11.7.0"
}
